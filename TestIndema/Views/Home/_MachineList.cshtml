        <section id="view-machine" class="view-section hidden">
          <div class="machine-list-layout">
            <!-- Control Bar (Search, Filters, Toggle Grid/List) -->
            <div class="control-bar">
              <!-- Search Bar -->
              <div class="search-box-wrapper">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="machine-search-input" data-i18n="machine_list_search_placeholder" placeholder="Search Machine ID or Model...">
              </div>
              
              <!-- Filters Button -->
              <button class="filter-btn" id="machine-filter-btn">
                <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4" y1="21" x2="4" y2="14"></line>
                  <line x1="4" y1="10" x2="4" y2="3"></line>
                  <line x1="12" y1="21" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12" y2="3"></line>
                  <line x1="20" y1="21" x2="20" y2="16"></line>
                  <line x1="20" y1="12" x2="20" y2="3"></line>
                  <line x1="1" y1="14" x2="7" y2="14"></line>
                  <line x1="9" y1="8" x2="15" y2="8"></line>
                  <line x1="17" y1="16" x2="23" y2="16"></line>
                </svg>
                <span data-i18n="history_btn_filter">Filters</span>
              </button>

              <!-- View Switcher (Grid / List) -->
              <div class="view-switcher">
                <button class="switch-btn active" id="view-grid-btn">
                  <svg class="switch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                  </svg>
                  <span data-i18n="layout_grid">Grid</span>
                </button>
                <button class="switch-btn" id="view-list-btn">
                  <svg class="switch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="8" y1="6" x2="21" y2="6"></line>
                    <line x1="8" y1="12" x2="21" y2="12"></line>
                    <line x1="8" y1="18" x2="21" y2="18"></line>
                    <line x1="3" y1="6" x2="3.01" y2="6"></line>
                    <line x1="3" y1="12" x2="3.01" y2="12"></line>
                    <line x1="3" y1="18" x2="3.01" y2="18"></line>
                  </svg>
                  <span data-i18n="layout_list">List</span>
                </button>
              </div>
            </div>

            <!-- Machine List Cards Grid -->
            <div class="machine-list-grid" id="machine-list-container">
              <!-- Dynamically rendered via JS -->
            </div>
          </div>
        </section>

