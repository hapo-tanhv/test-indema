            </div>
            <div class="alarm-modal-body">
              <div class="modal-detail-row">
                <span class="detail-label" data-i18n="alarm_modal_lbl_time">Thời gian:</span>
                <span class="detail-val" id="modal-detail-time">14:22:15 12/10/2024</span>
              </div>
              <div class="modal-detail-row">
                <span class="detail-label" data-i18n="alarm_modal_lbl_severity">Mức độ:</span>
                <span class="detail-val" id="modal-detail-severity">Nghiêm trọng</span>
              </div>
              <div class="modal-detail-row">
                <span class="detail-label" data-i18n="alarm_modal_lbl_code">Thiết bị / Mã lỗi:</span>
                <span class="detail-val font-bold" id="modal-detail-code">ERR-DOWNTIME-902 (MÁY ÉP #08)</span>
              </div>
              <div class="modal-detail-row">
                <span class="detail-label" data-i18n="alarm_modal_lbl_desc">Mô tả sự cố:</span>
                <span class="detail-val desc" id="modal-detail-desc">Áp suất thủy lực vượt ngưỡng cho phép (185 bar). Hệ thống tự động ngắt khẩn cấp.</span>
              </div>
              <div class="modal-detail-row">
                <span class="detail-label">Trạng thái hiện tại:</span>
                <span class="detail-val" id="modal-detail-status">Đang xử lý</span>
              </div>
            </div>
            <div class="alarm-modal-footer">
              <button class="alarm-modal-btn btn-ack" id="alarm-btn-ack">Xác nhận xử lý (Acknowledge)</button>
              <button class="alarm-modal-btn btn-resolve" id="alarm-btn-resolve">Đã khắc phục xong (Resolve)</button>
            </div>
          </div>
        </div>

