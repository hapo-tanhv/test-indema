                  <line x1="20" y1="21" x2="20" y2="16"></line>
                  <line x1="20" y1="12" x2="20" y2="3"></line>
                  <line x1="2" y1="14" x2="6" y2="14"></line>
                  <line x1="10" y1="8" x2="14" y2="8"></line>
                  <line x1="18" y1="16" x2="22" y2="16"></line>
                </svg>
                <span data-i18n="history_btn_filter">Lọc</span>
              </button>
            </div>

            <!-- Table Panel -->
            <div class="alarm-table-panel">
              <div class="alarm-table-container">
                <table class="alarm-table">
                  <thead>
                    <tr>
                      <th style="width: 140px;" data-i18n="alarm_tbl_col_time">THỜI GIAN</th>
                      <th style="width: 140px;" data-i18n="alarm_tbl_col_severity">MỨC ĐỘ</th>
                      <th style="width: 220px;" data-i18n="alarm_tbl_col_code">MÃ LỖI / THIẾT BỊ</th>
                      <th data-i18n="alarm_tbl_col_desc">MÔ TẢ CHI TIẾT</th>
                      <th style="width: 160px;" data-i18n="alarm_tbl_col_status">TRẠNG THÁI</th>
                    </tr>
                  </thead>
                  <tbody id="alarm-table-body">
                    <!-- Dynamically populated via JS -->
                  </tbody>
                </table>
              </div>
              
              <!-- Footer Pagination -->
              <div class="alarm-table-footer">
                <span class="footer-info" id="alarm-table-info">Hiển thị 1 - 10 trên tổng số 24 cảnh báo</span>
                <div class="pagination" id="alarm-pagination">
                  <!-- Generated via JS -->
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Alarm Interactive Acknowledge Modal -->
        <div class="alarm-modal-overlay hidden" id="alarm-action-modal">
          <div class="alarm-modal-card">
            <div class="alarm-modal-header">
              <h3 class="alarm-modal-title" data-i18n="alarm_modal_title">Xử Lý Cảnh Báo Lỗi</h3>
