        <section id="view-alert" class="view-section hidden">
          <div class="alarm-layout">
            <!-- Top KPI Cards Row -->
            <div class="alarm-kpi-row">
              <!-- KPI Card 1: Critical errors -->
              <div class="alarm-kpi-card border-red">
                <div class="alarm-kpi-content">
                  <span class="alarm-kpi-label" data-i18n="alarm_kpi_critical">LỖI NGHIÊM TRỌNG</span>
                  <span class="alarm-kpi-value color-red" id="alarm-kpi-critical">03</span>
                  <span class="alarm-kpi-subtext" data-i18n="alarm_kpi_critical_sub">Yêu cầu can thiệp ngay lập tức</span>
                </div>
                <div class="alarm-kpi-badge">
                  <svg class="alarm-icon-svg text-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                  </svg>
                </div>
              </div>

              <!-- KPI Card 2: System warnings -->
              <div class="alarm-kpi-card border-orange">
                <div class="alarm-kpi-content">
                  <span class="alarm-kpi-label" data-i18n="alarm_kpi_warning">CẢNH BÁO HỆ THỐNG</span>
                  <span class="alarm-kpi-value color-orange" id="alarm-kpi-warning">12</span>
                  <span class="alarm-kpi-subtext" data-i18n="alarm_kpi_warning_sub">Kiểm tra bảo trì định kỳ</span>
                </div>
                <div class="alarm-kpi-badge">
                  <svg class="alarm-icon-svg text-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                  </svg>
                </div>
              </div>

              <!-- KPI Card 3: Uptime and stats -->
              <div class="alarm-kpi-card">
                <div class="alarm-kpi-content" style="width: 60%;">
                  <span class="alarm-kpi-label" data-i18n="alarm_kpi_uptime">THỜI GIAN HOẠT ĐỘNG (UPTIME)</span>
                  <span class="alarm-kpi-value color-green" id="alarm-kpi-uptime">98.4%</span>
                  <div class="alarm-kpi-sub-stats">
                    <div class="sub-stat">
                      <span class="sub-lbl" data-i18n="alarm_kpi_uptime_sub">DOWNTIME (HÔM NAY)</span>
                      <span class="sub-val text-orange" id="alarm-kpi-downtime">22 <span data-i18n="alarm_unit_minute">Phút</span></span>
                    </div>
                    <div class="sub-stat">
                      <span class="sub-lbl" data-i18n="alarm_kpi_strokes_lbl">SỐ NHỊP (STROKE COUNT)</span>
                      <span class="sub-val" id="alarm-kpi-strokes">124,502</span>
                    </div>
                  </div>
                </div>
                <div class="alarm-kpi-gauge-container">
                  <svg class="alarm-gauge-svg" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="38" stroke="#16223f" stroke-width="7" fill="none" />
                    <circle cx="50" cy="50" r="38" stroke="#00e676" stroke-width="7" fill="none"
                            stroke-dasharray="238.76" stroke-dashoffset="3.8" stroke-linecap="round"
                            transform="rotate(-90 50 50)" />
                  </svg>
                </div>
              </div>
            </div>

            <!-- Filter & Search Bar -->
            <div class="alarm-filter-bar">
              <div class="alarm-filter-tabs" id="alarm-severity-tabs">
                <button class="alarm-tab-btn active" data-severity="all"><span data-i18n="alarm_filter_severity_all">Tất cả</span> <span class="badge-count" id="alarm-count-all">24</span></button>
                <button class="alarm-tab-btn" data-severity="critical" data-i18n="alarm_filter_severity_critical">Nghiêm trọng</button>
                <button class="alarm-tab-btn" data-severity="warning" data-i18n="alarm_filter_severity_warning">Cảnh báo</button>
