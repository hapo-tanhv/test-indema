        <section id="view-machine-detail" class="view-section hidden">
          <div class="machine-detail-layout">
            <!-- Top Action Bar (Back button and Title) -->
            <div class="detail-action-bar">
              <button class="back-btn" id="machine-detail-back-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width: 16px; height: 16px;">
                  <line x1="19" y1="12" x2="5" y2="12"></line>
                  <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                <span data-i18n="btn_back">Quay lại danh sách</span>
              </button>
              
              <div class="detail-title-block">
                <h2 class="detail-main-title" id="machine-detail-title">MÁY DẬP SỐ #01</h2>
                <div class="machine-status-badge" style="margin-top: 4px;">
                  <span class="status-indicator-dot running" id="machine-detail-status-dot"></span>
                  <span class="status-text text-running" id="machine-detail-status-text">ĐANG HOẠT ĐỘNG</span>
                </div>
              </div>
            </div>

            <!-- Main Detail Grid -->
            <div class="detail-grid">
              <!-- Left Column: Heavy Stamp Animation & Speed -->
              <div class="detail-left-col">
                <div class="machine-stamp-card" id="machine-stamp-card">
                  <div class="stamp-image-viewport">
                    <img src="@Url.Content("~/Image/maydap.jpeg")" alt="Stamping Press" class="machine-stamp-image" id="machine-detail-stamp-img">
                    <!-- Glow indicator on impact -->
                    <div class="stamp-glow" id="machine-detail-stamp-glow"></div>
                  </div>
                  <div class="stamp-card-footer">
                    <div class="live-speed-indicator">
                      <span class="live-pulse"></span>
                      <span class="speed-lbl" data-i18n="machine_detail_speed_lbl">Tốc độ vận hành:</span>
                      <span class="speed-val" id="machine-detail-speed-val">120 <span class="unit" data-i18n="machine_detail_speed_unit">nhịp/phút</span></span>
                    </div>
                    <div class="oee-gauge-mini">
                      <span class="oee-lbl">OEE:</span>
                      <span class="oee-val" id="machine-detail-oee-val">92%</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Right Column: Stats & Chart -->
              <div class="detail-right-col">
                <!-- Stats Cards Grid -->
                <div class="detail-stats-grid">
                  <!-- Total Strokes -->
                  <div class="detail-stat-card">
                    <span class="stat-card-label" data-i18n="kpi_strokes_title">TỔNG SỐ LẦN DẬP</span>
                    <span class="stat-card-value value-highlight" id="machine-detail-strokes-val">1.256 <span class="unit" data-i18n="overview_strokes_unit">lần</span></span>
                  </div>
                  <!-- Load Capacity -->
                  <div class="detail-stat-card">
                    <span class="stat-card-label" data-i18n="machine_list_load">CÔNG SUẤT TẢI</span>
                    <span class="stat-card-value" id="machine-detail-load-val">78%</span>
                  </div>
                  <!-- Runtime -->
                  <div class="detail-stat-card">
                    <span class="stat-card-label" data-i18n="machine_list_runtime">THỜI GIAN CHẠY</span>
                    <span class="stat-card-value" id="machine-detail-runtime-val">08:45:12</span>
                  </div>
                  <!-- Stoptime -->
                  <div class="detail-stat-card">
                    <span class="stat-card-label" data-i18n="machine_list_stoptime">THỜI GIAN DỪNG</span>
                    <span class="stat-card-value" id="machine-detail-stoptime-val">00:15:30</span>
                  </div>
                </div>

                <!-- Weekly Production Chart Panel -->
                <div class="detail-chart-panel">
                  <div class="panel-header" style="margin-bottom: 15px;">
                    <h3 class="panel-title" data-i18n="machine_detail_chart_title">XU HƯỚNG SẢN LƯỢNG TUẦN</h3>
                    <p class="panel-subtitle" data-i18n="machine_detail_chart_desc">Thống kê sản lượng dập trong 7 ngày qua</p>
                  </div>
                  <div class="chart-container-wrapper" style="position: relative; height: 260px; width: 100%;">
                    <canvas id="machine-detail-chart"></canvas>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 3. VIEW LỊCH SỬ -->
