      <header class="header" id="header">
        <!-- Page Title & Subtitle -->
        <div class="header-title-area">
          <h1 class="header-title" id="page-title">TỔNG QUAN HỆ THỐNG</h1>
          <p class="header-subtitle" id="page-subtitle">Giám sát trạng thái máy</p>
        </div>

        <!-- Header Widgets -->
        <div class="header-widgets">
          <!-- Time Static Display -->
          <div class="time-widget">
            <span class="time-value">10:30:45</span>
            <span class="date-value">20/05/2024</span>
          </div>

          <!-- Notification Bell Icon -->
          <div class="notify-widget">
            <svg class="notify-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <span class="notify-badge">3</span>
          </div>

          <!-- Language Selector Switcher -->
          <div class="lang-switcher-widget">
            <button class="lang-toggle-btn" id="header-lang-btn" style="padding: 6px 10px;">
              <span id="header-lang-flag" style="display: flex; align-items: center; justify-content: center;">
                <svg viewBox="0 0 30 20" style="width: 20px; height: 14px; border-radius: 2px;">
                  <rect width="30" height="20" fill="#da251d"/>
                  <polygon points="15,4 16.35,8.15 20.7,8.15 17.2,10.7 18.5,14.85 15,12.3 11.5,14.85 12.8,10.7 9.3,8.15 13.65,8.15" fill="#ffff00"/>
                </svg>
              </span>
            </button>
            <div class="lang-dropdown hidden" id="header-lang-dropdown">
              <div class="lang-dropdown-item" data-lang="vi" style="display: flex; align-items: center; gap: 10px;">
                <span style="display: flex; align-items: center;">
                  <svg viewBox="0 0 30 20" style="width: 20px; height: 14px; border-radius: 2px;">
                    <rect width="30" height="20" fill="#da251d"/>
                    <polygon points="15,4 16.35,8.15 20.7,8.15 17.2,10.7 18.5,14.85 15,12.3 11.5,14.85 12.8,10.7 9.3,8.15 13.65,8.15" fill="#ffff00"/>
                  </svg>
                </span>
                <span class="lang-text" style="font-weight: 600;">Tiếng Việt</span>
              </div>
              <div class="lang-dropdown-item" data-lang="en" style="display: flex; align-items: center; gap: 10px;">
                <span style="display: flex; align-items: center;">
                  <svg viewBox="0 0 30 20" style="width: 20px; height: 14px; border-radius: 2px; border: 1px solid rgba(255, 255, 255, 0.1);">
                    <rect width="30" height="20" fill="#fff"/>
                    <rect width="30" height="1.54" y="0" fill="#b22234"/>
                    <rect width="30" height="1.54" y="3.08" fill="#b22234"/>
                    <rect width="30" height="1.54" y="6.15" fill="#b22234"/>
                    <rect width="30" height="1.54" y="9.23" fill="#b22234"/>
                    <rect width="30" height="1.54" y="12.31" fill="#b22234"/>
                    <rect width="30" height="1.54" y="15.38" fill="#b22234"/>
                    <rect width="30" height="1.54" y="18.46" fill="#b22234"/>
                    <rect width="12" height="10.77" fill="#3c3b6e"/>
                    <circle cx="3" cy="2.5" r="0.6" fill="#fff"/>
                    <circle cx="6" cy="2.5" r="0.6" fill="#fff"/>
                    <circle cx="9" cy="2.5" r="0.6" fill="#fff"/>
                    <circle cx="4.5" cy="5" r="0.6" fill="#fff"/>
                    <circle cx="7.5" cy="5" r="0.6" fill="#fff"/>
                    <circle cx="3" cy="7.5" r="0.6" fill="#fff"/>
                    <circle cx="6" cy="7.5" r="0.6" fill="#fff"/>
                    <circle cx="9" cy="7.5" r="0.6" fill="#fff"/>
                  </svg>
                </span>
                <span class="lang-text" style="font-weight: 600;">English</span>
              </div>
            </div>
          </div>

          <!-- User Profile info -->
          <div class="user-profile">
            <div class="user-avatar">AD</div>
            <div class="user-info">
              <span class="user-name">Admin</span>
              <svg class="user-dropdown-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>
        </div>
      </header>
