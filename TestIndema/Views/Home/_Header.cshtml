      <header class="header" id="header">
        <!-- Page Title & Subtitle -->
        <div class="header-title-area">
          <h1 class="header-title" id="page-title">TỔNG QUAN HỆ THỐNG</h1>
          <p class="header-subtitle" id="page-subtitle">Giám sát trạng thái 10 máy dập</p>
        </div>

        <!-- Header Widgets -->
        <div class="header-widgets">
          <!-- Time Static Display -->
          <div class="time-widget">
            <span class="time-value">10:30:45</span>
