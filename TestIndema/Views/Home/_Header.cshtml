          </div>

          <!-- Notification Bell Icon -->
          <div class="notify-widget">
            <svg class="notify-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
