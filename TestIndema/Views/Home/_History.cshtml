        <section id="view-history" class="view-section hidden">
          <div class="history-layout">
            <!-- Row 1: 4 KPI Cards -->
            <div class="history-kpi-row">
              <!-- KPI Card 1 -->
              <div class="h-kpi-card accent-blue">
                <span class="h-kpi-label" data-i18n="history_kpi_total_strokes">TỔNG SẢN LƯỢNG NGÀY</span>
                <span class="h-kpi-value">12.568 <span class="unit" data-i18n="overview_strokes_unit">Lần</span></span>
                <div class="h-kpi-trend trend-up">
                  <svg class="trend-arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7"></line>
                    <polyline points="7 7 17 7 17 17"></polyline>
                  </svg>
                  <span>+8.5% <span data-i18n="history_kpi_total_strokes_sub">so với hôm qua</span></span>
                </div>
              </div>

              <!-- KPI Card 2 -->
              <div class="h-kpi-card accent-grey">
                <span class="h-kpi-label" data-i18n="history_kpi_uptime">TỔNG SẢN LƯỢNG TUẦN</span>
                <span class="h-kpi-value">84.210 <span class="unit" data-i18n="overview_strokes_unit">Lần</span></span>
                <div class="h-kpi-trend trend-up">
                  <svg class="trend-arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7"></line>
                    <polyline points="7 7 17 7 17 17"></polyline>
                  </svg>
                  <span>+4.5% <span data-i18n="history_kpi_uptime_sub">so với tuần trước</span></span>
                </div>
              </div>

              <!-- KPI Card 3 -->
              <div class="h-kpi-card accent-blue">
                <span class="h-kpi-label" data-i18n="history_kpi_monthly_strokes">TỔNG SẢN LƯỢNG THÁNG</span>
                <span class="h-kpi-value">340.500 <span class="unit" data-i18n="overview_strokes_unit">Lần</span></span>
                <div class="h-kpi-trend trend-up">
                  <svg class="trend-arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7"></line>
                    <polyline points="7 7 17 7 17 17"></polyline>
                  </svg>
                  <span>+12.4% <span data-i18n="history_kpi_monthly_strokes_sub">so với tháng trước</span></span>
                </div>
              </div>

              <!-- KPI Card 4 -->
              <div class="h-kpi-card accent-green" style="display: flex; flex-direction: column; justify-content: center; height: 100%;">
                <span class="h-kpi-label" data-i18n="history_kpi_downtime">HIỆU SUẤT</span>
                <span class="h-kpi-value" style="margin-top: 8px;">98.4%</span>
              </div>
            </div>

            <!-- Toolbar (Search, Date, Filter, Export) -->
            <div class="history-toolbar">
              <div class="search-box-wrapper">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="history-search-input" data-i18n="history_search_placeholder" placeholder="Tìm theo Mã máy...">
              </div>

              <div class="date-picker-wrapper">
                <svg class="calendar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="16" y1="2" x2="16" y2="6"></line>
                  <line x1="8" y1="2" x2="8" y2="6"></line>
                  <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <input type="text" id="history-date-range" data-i18n="history_date_placeholder" placeholder="Chọn khoảng thời gian...">
                <svg class="dropdown-arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </div>

              <div class="filter-btn-wrapper" style="position: relative;">
                <button class="filter-btn" id="history-filter-btn">
                  <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="21" x2="4" y2="14"></line>
                    <line x1="4" y1="10" x2="4" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12" y2="3"></line>
                    <line x1="20" y1="21" x2="20" y2="16"></line>
                    <line x1="20" y1="12" x2="20" y2="3"></line>
                    <line x1="1" y1="14" x2="7" y2="14"></line>
                    <line x1="9" y1="8" x2="15" y2="8"></line>
                    <line x1="17" y1="16" x2="23" y2="16"></line>
                  </svg>
                  <span data-i18n="history_btn_filter">Lọc</span>
                </button>
                <div class="filter-dropdown hidden" id="history-filter-dropdown">
                  <div class="filter-group">
                    <span class="filter-group-title" data-i18n="history_filter_status_lbl">Trạng thái</span>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-status" value="all" checked>
                      <span data-i18n="history_filter_status_all">Tất cả</span>
                    </label>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-status" value="running">
                      <span data-i18n="history_filter_status_completed">Hoàn thành</span>
                    </label>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-status" value="stopped">
                      <span data-i18n="history_filter_status_stopped">Không hoàn thành</span>
                    </label>
                  </div>
                  <div class="filter-group" style="margin-top: 10px;">
                    <span class="filter-group-title" data-i18n="history_filter_quality_lbl">Chất lượng</span>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-quality" value="all" checked>
                      <span data-i18n="history_filter_quality_all">Tất cả</span>
                    </label>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-quality" value="high">
                      <span data-i18n="history_filter_quality_high">Đạt chuẩn (100%)</span>
                    </label>
                    <label class="filter-checkbox-label">
                      <input type="radio" name="filter-quality" value="low">
                      <span data-i18n="history_filter_quality_low">Không đạt (< 100%)</span>
                    </label>
                  </div>
                  <div class="filter-actions">
                    <button class="filter-action-btn reset" id="filter-reset-btn" data-i18n="history_filter_btn_reset">Reset</button>
                    <button class="filter-action-btn apply" id="filter-apply-btn" data-i18n="history_filter_btn_apply">Lọc</button>
                  </div>
                </div>
              </div>

              <button class="export-btn" id="history-export-btn">
                <svg class="export-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                <span data-i18n="history_btn_export">XUẤT BÁO CÁO</span>
              </button>
            </div>

            <!-- Table Container -->
            <div class="table-container">
              <table class="history-table">
                <thead>
                  <tr>
                    <th data-i18n="history_tbl_col_machine">MÃ MÁY</th>
                    <th data-i18n="history_tbl_col_start">THỜI GIAN BẮT ĐẦU</th>
                    <th data-i18n="history_tbl_col_end">THỜI GIAN KẾT THÚC</th>
                    <th data-i18n="history_tbl_col_strokes" style="text-align: center;">SẢN LƯỢNG THỰC TẾ</th>
                    <th data-i18n="history_tbl_col_target" style="text-align: center;">SẢN LƯỢNG TIÊU CHUẨN</th>
                    <th data-i18n="history_tbl_col_efficiency">HIỆU SUẤT</th>
                    <th data-i18n="history_tbl_col_status" style="text-align: center;">TRẠNG THÁI</th>
                    <th data-i18n="history_tbl_col_details" style="text-align: center;">CHI TIẾT</th>
                  </tr>
                </thead>
                <tbody id="history-table-body">
                  <!-- Dynamically rendered via JS -->
                </tbody>
              </table>
              <div class="table-footer">
                <span class="table-info" id="history-table-info">Hiển thị 1 - 5 của 24 bản ghi</span>
                <div class="pagination" id="history-pagination">
                  <!-- Dynamically rendered via JS -->
                </div>
              </div>
            </div>


          </div>
        </section>

