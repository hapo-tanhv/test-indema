                  <button class="segment-btn" data-range="week" data-i18n="report_btn_week">TUẦN</button>
                  <button class="segment-btn" data-range="month" data-i18n="report_btn_month">THÁNG</button>
                  <button class="segment-btn" data-range="year" data-i18n="report_btn_year">NĂM</button>
