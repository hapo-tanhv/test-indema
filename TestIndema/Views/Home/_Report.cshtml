                  <span class="r-kpi-value" id="r-kpi-strokes-target" style="font-weight: 700;">
                    <span style="color: #00d2ff;">0</span> / <span style="color: #ffffff;">0</span>
                  </span>
                  <span class="r-kpi-subtext" id="r-kpi-strokes-target-pct" style="color: var(--text-secondary); font-size: 0.75rem; margin-top: 4px;">0%</span>
                </div>
              </div>

              <!-- Card 2: Order Progress -->
              <div class="r-kpi-card">
                <div class="r-kpi-content" style="width: 100%;">
