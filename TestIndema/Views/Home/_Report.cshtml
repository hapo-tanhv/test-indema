                      <th data-i18n="report_tbl_col_oee_lbl" style="text-align: center;">HIỆU SUẤT (OEE)</th>
                      <th data-i18n="history_tbl_col_status" style="text-align: center;">TRẠNG THÁI</th>
                    </tr>
                  </thead>
                  <tbody id="report-table-body">
                    <!-- Dynamically rendered via JS -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>
