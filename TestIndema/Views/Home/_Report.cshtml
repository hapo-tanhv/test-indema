                <a href="javascript:void(0)" class="r-history-link" id="report-view-history-link" data-i18n="report_table_history_link">Xem lịch sử đầy đủ</a>
              </div>
              <div class="r-table-container">
                <table class="report-table">
                  <thead>
                    <tr>
                      <th data-i18n="report_tbl_col_shift_lbl">CA LÀM VIỆC</th>
                      <th data-i18n="report_tbl_col_press_lbl">MÁY DẬP</th>
                      <th data-i18n="history_tbl_col_strokes" style="text-align: center;">SẢN LƯỢNG THỰC TẾ</th>
                      <th data-i18n="report_kpi_uptime" style="text-align: center;">THỜI GIAN HOẠT ĐỘNG</th>
