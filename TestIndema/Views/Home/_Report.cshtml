                      <span class="total-errors-lbl" data-i18n="report_chart_yield_progress" style="font-size: 0.65rem; text-transform: uppercase; margin-top: 2px;">Đạt mục tiêu</span>
                    </div>
                  </div>
                  <div class="r-pie-legend" id="r-yield-legend-container" style="display: flex; flex-direction: column; gap: 10px; justify-content: center; margin-left: 20px;">
                    <div class="legend-item" style="display: flex; justify-content: space-between; font-size: 0.8rem; width: 140px;">
                      <span><span class="legend-dot" style="background-color: #00d2ff;"></span><span data-i18n="report_legend_actual">Thực tế</span></span>
                      <span id="r-yield-legend-actual" style="color: #fff; font-weight: 700;">0</span>
                    </div>
                    <div class="legend-item" style="display: flex; justify-content: space-between; font-size: 0.8rem; width: 140px;">
                      <span><span class="legend-dot" style="background-color: #16223f; border: 1px solid #4e5b6e;"></span><span data-i18n="report_legend_remaining">Còn lại</span></span>
                      <span id="r-yield-legend-remaining" style="color: #fff; font-weight: 700;">0</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Operations Table Panel -->
            <div class="report-table-panel">
