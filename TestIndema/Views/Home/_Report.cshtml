                    <span id="achievement-count-standard" style="color: #fff; font-weight: 700;">--</span>
                  </div>
                  <div style="display: flex; justify-content: space-between; font-size: 0.75rem;">
                    <span class="legend-item"><span class="legend-dot" style="background-color: #ef4444;"></span><span data-i18n="achievement_legend_low">Không đạt (< 100%)</span></span>
                    <span id="achievement-count-low" style="color: #fff; font-weight: 700;">--</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Bottom Row: Performance Chart & Stability Gauge -->
            <div class="history-bottom-row" style="margin-top: 30px; margin-bottom: 30px;">
              <!-- Weekly Performance Panel -->
              <div class="chart-panel">
                <div class="chart-panel-header">
                  <h3 class="chart-panel-title" data-i18n="history_chart_performance_title">Phân Tích Hiệu Suất Sản Lượng</h3>
                  <p class="chart-panel-subtitle" data-i18n="history_chart_performance_desc">So sánh sản lượng mục tiêu vs thực tế</p>
                  <div class="chart-legend">
                    <span class="legend-item"><span class="legend-dot actual"></span><span data-i18n="history_legend_actual">Thực tế</span></span>
                    <span class="legend-item"><span class="legend-dot target"></span><span data-i18n="history_legend_target">Mục tiêu</span></span>
                  </div>
                </div>
                <div class="chart-canvas-wrapper">
                  <canvas id="weekly-performance-chart"></canvas>
                </div>
              </div>

              <!-- Yield Performance Donut -->
