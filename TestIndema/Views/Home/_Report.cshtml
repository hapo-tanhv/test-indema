                  <span class="r-kpi-value" id="r-kpi-oee" style="color: #00d2ff; font-weight: 700;">0%</span>
                  <span class="r-kpi-subtext" style="color: var(--text-secondary); font-size: 0.72rem; margin-top: 4px;">= Thực tế / Kế hoạch</span>
                </div>
              </div>

              <!-- Card 4: Time Efficiency -->
              <div class="r-kpi-card">
                <div class="r-kpi-content" style="width: 100%;">
                  <span class="r-kpi-label" data-i18n="report_kpi_time_eff">HIỆU SUẤT THỜI GIAN</span>
                  <span class="r-kpi-value" id="r-kpi-time-eff" style="color: #00d2ff; font-weight: 700;">0%</span>
                  <span class="r-kpi-subtext" style="color: var(--text-secondary); font-size: 0.72rem; margin-top: 4px;">= Thời gian chạy / Thời gian ca</span>
                </div>
              </div>



              <!-- Card 6: Running Time -->
              <div class="r-kpi-card">
                <div class="r-kpi-content" style="width: 100%;">
                  <span class="r-kpi-label" data-i18n="report_kpi_run_time">THỜI GIAN CHẠY MÁY</span>
